# === Google Gemini ===
GEMINI_API_KEY=sua-chave-aqui
GEMINI_MODEL=gemini-1.5-flash        # ou gemini-2.0-flash-exp, etc
GEMINI_EMBEDDING_MODEL=text-embedding-004

# === PostgreSQL (pgvector) ===
PG_HOST=localhost
PG_PORT=5432
PG_DATABASE=gestores_ia
PG_USER=postgres
PG_PASSWORD=postgres

# === App Configuration ===
APP_HOST=0.0.0.0
APP_PORT=8000
RAG_TOP_K=8
RAG_RELEVANCE_THRESHOLD=7
MAX_REFINEMENT_ITERATIONS=2
CONVERSATION_HISTORY_LIMIT=10

# === Monitoring (LangSmith - Opcional) ===
LANGCHAIN_TRACING_V2=false
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_API_KEY=sua-chave-aqui
LANGCHAIN_PROJECT=sofia-ia-rag

# === Outros (Opcionais) ===
# OPENAI_API_KEY=sk-...
# VOYAGE_API_KEY=...
# AZURE_STORAGE_CONNECTION_STRING=...
